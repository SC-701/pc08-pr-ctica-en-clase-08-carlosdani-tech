@page "{id:guid}"
@model Web.Pages.Productos.EliminarModel
@{
    ViewData["Title"] = "Eliminar producto";
}

<div class="container pb-5">
    <form method="post">
        <input type="hidden" name="id" value="@Model.Producto.Id" />
        <div class="col-md-8">
            <h1 class="mb-4">Eliminar Producto</h1>
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@Model.Producto.Nombre</h5>
                    <h6 class="card-subtitle mb-2 text-muted">@Model.Producto.Categoria / @Model.Producto.SubCategoria</h6>
                    <div class="card-text">
                        <div>
                            <b>Codigo:</b>
                            @Model.Producto.CodigoBarras
                        </div>
                        <div>
                            <b>Precio CRC:</b>
                            @Model.Producto.Precio.ToString("N2")
                        </div>
                        <div>
                            <b>Precio USD:</b>
                            @Model.Producto.PrecioUSD.ToString("N2")
                        </div>
                        <div>
                            <b>Stock:</b>
                            @Model.Producto.Stock
                        </div>
                    </div>
                    <p class="card-text">
                        <small class="text-muted">
                            @Model.Producto.Descripcion
                        </small>
                    </p>
                </div>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3 mb-4">
            <a type="button" class="btn btn-primary" asp-page="./Index">Regresar</a>
            <button type="submit" class="btn btn-danger">Eliminar</button>
        </div>
    </form>
</div>
