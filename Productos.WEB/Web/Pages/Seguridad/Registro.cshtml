@page
@model Web.Pages.Cuenta.RegistroModel
@{
    ViewData["Title"] = "Registro";
}

<div class="container pb-5">
    <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto">
        <div class="card shadow-sm">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <h1 class="h2 mb-2">Registrarse</h1>
                    <p class="text-muted mb-0">Crea una cuenta para acceder al modulo de productos.</p>
                </div>

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="usuario.NombreUsuario" class="form-label">Nombre de usuario</label>
                        <input asp-for="usuario.NombreUsuario" type="text" class="form-control" placeholder="Nombre de usuario" />
                        <span asp-validation-for="usuario.NombreUsuario" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="usuario.CorreoElectronico" class="form-label">Correo electronico</label>
                        <input asp-for="usuario.CorreoElectronico" type="email" class="form-control" placeholder="correo@dominio.com" />
                        <span asp-validation-for="usuario.CorreoElectronico" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="usuario.Password" class="form-label">Contrasena</label>
                        <input asp-for="usuario.Password" type="password" class="form-control" placeholder="Contrasena" />
                        <span asp-validation-for="usuario.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="usuario.ConfirmarPassword" class="form-label">Confirmar contrasena</label>
                        <input asp-for="usuario.ConfirmarPassword" type="password" class="form-control" placeholder="Confirmar contrasena" />
                        <span asp-validation-for="usuario.ConfirmarPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Registrarse</button>
                    </div>
                </form>

                <hr class="my-4" />
                <div class="text-center">
                    <a asp-page="/Seguridad/Login" class="link-secondary text-decoration-none">Ya tengo cuenta</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
